            const studyBtn = document.getElementById('nav-study');
            const quizBtn = document.getElementById('nav-quiz');
            
            if (page === 'study') {
                studyBtn.className = "nav-active px-6 py-2.5 rounded-xl font-bold text-sm md:text-base transition duration-300";
                quizBtn.className = "px-6 py-2.5 rounded-xl font-bold text-sm md:text-base text-white hover:text-blue-200 transition duration-300";
            } else {
                studyBtn.className = "px-6 py-2.5 rounded-xl font-bold text-sm md:text-base text-white hover:text-blue-200 transition duration-300";
                quizBtn.className = "nav-active px-6 py-2.5 rounded-xl font-bold text-sm md:text-base transition duration-300";
                // Show intro rather than direct game state if first time
                document.getElementById('quiz-intro').classList.remove('hidden');
                document.getElementById('quiz-content').classList.add('hidden');
                document.getElementById('quiz-result').classList.add('hidden');
            }
        }

        // --- Card Generator ---
        function createCard(item) {
            const isApp = item.type === '應用';
            const themeBorder = isApp ? 'border-orange-400' : 'border-emerald-400';
            const badgeClass = isApp ? 'bg-orange-100 text-orange-700' : 'bg-emerald-100 text-emerald-700';
            
            return `
                <div class="vocab-card h-52 perspective cursor-pointer" onclick="this.classList.toggle('card-flipped')">
                    <div class="card-flip-inner relative w-full h-full text-center">
                        <!-- Front Face -->
                        <div class="card-front absolute w-full h-full bg-white rounded-2xl shadow-sm p-4 flex flex-col justify-center items-center border-b-4 ${themeBorder}">
                            <span class="absolute top-3 left-3 text-[10px] font-bold px-2 py-0.5 rounded-full ${badgeClass}">${item.type}</span>
                            <h2 class="text-2xl md:text-3xl font-bold text-gray-800 mb-1">${item.word}</h2>
                            <p class="text-indigo-500 text-xs md:text-sm font-semibold">${item.jyutping}</p>
                            <p class="text-gray-400 text-[10px] mt-2">${item.lesson}</p>
                            <button onclick="event.stopPropagation(); speak('${item.word}')" class="mt-3 p-1.5 bg-gray-50 rounded-full hover:bg-blue-100 transition border border-gray-100 text-xs shadow-sm">🔊 廣東話</button>
                        </div>
                        <!-- Back Face -->
                        <div class="card-back absolute w-full h-full bg-slate-50 text-slate-900 rounded-2xl shadow-sm p-4 flex flex-col justify-center items-center border-b-4 border-indigo-400">
                            <div class="text-left w-full overflow-hidden">
                                <p class="text-[9px] uppercase font-bold text-slate-400 mb-0.5">中文解釋</p>
                                <p class="text-xs md:text-sm font-medium leading-snug text-slate-700 mb-2">${item.zh}</p>
                                <div class="pt-1.5 border-t border-slate-200">
                                    <p class="text-[9px] uppercase font-bold text-slate-400 mb-0.5">English</p>
                                    <p class="text-xs italic font-medium text-slate-600">${item.en}</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            `;
        }

        function renderContent(filterUnitId = 'all') {
            const container = document.getElementById('content-area');
            container.innerHTML = '';
            const unitsToDisplay = filterUnitId === 'all' ? Object.keys(unitNames) : [filterUnitId];

            unitsToDisplay.forEach(uId => {
                const unitData = vocabData.filter(i => i.unit === uId);
                const appVocab = unitData.filter(i => i.type === '應用');
                const readVocab = unitData.filter(i => i.type === '認讀');

                const section = document.createElement('div');
                section.className = 'mb-12 bg-white rounded-3xl p-6 shadow-sm border border-indigo-50/50';
                section.innerHTML = `
                    <h2 class="text-xl md:text-2xl font-bold text-slate-800 mb-6 flex items-center">
                        <span class="bg-indigo-600 w-2 h-7 rounded-full mr-3 shadow-md"></span>
                        ${unitNames[uId]}
                    </h2>
                    
                    ${appVocab.length > 0 ? `
                    <div class="mb-8">
                        <h3 class="text-sm font-bold text-orange-600 mb-4 flex items-center bg-orange-50/50 px-4 py-1.5 rounded-full inline-block">✍️ 應用詞彙部</h3>
                        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
                            ${appVocab.map(createCard).join('')}
                        </div>
                    </div>` : ''}

                    ${readVocab.length > 0 ? `
                    <div>
                        <h3 class="text-sm font-bold text-emerald-600 mb-4 flex items-center bg-emerald-50/50 px-4 py-1.5 rounded-full inline-block">📖 認讀詞彙部</h3>
                        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
                            ${readVocab.map(createCard).join('')}
                        </div>
                    </div>` : ''}
                `;
                container.appendChild(section);
            });
        }

        function filterUnit(unitId) {
            document.querySelectorAll('.unit-btn').forEach(btn => {
                btn.classList.remove('bg-indigo-600', 'text-white');
                btn.classList.add('bg-white', 'text-indigo-600');
            });
            event.target.classList.remove('bg-white', 'text-indigo-600');
            event.target.classList.add('bg-indigo-600', 'text-white');
            renderContent(unitId);
        }

        // --- Quiz System ---
        let currentQuestionIndex = 0;
        let score = 0;
        let quizQuestions = [];
        const TOTAL_QUESTIONS = 10;

        function startQuiz() {
            score = 0;
            currentQuestionIndex = 0;
            
            // Filter only apply type which has fill-in-the-blank sentences
            const quizPool = vocabData.filter(v => v.type === '應用' && v.sentence);
            
            // Randomly select 10 unique questions
            quizQuestions = [...quizPool].sort(() => 0.5 - Math.random()).slice(0, TOTAL_QUESTIONS);
            
            document.getElementById('quiz-intro').classList.add('hidden');
            document.getElementById('quiz-result').classList.add('hidden');
            document.getElementById('quiz-content').classList.remove('hidden');
            document.getElementById('quiz-score').textContent = `累積得分: ${score}`;
            
            showQuestion();
        }

        function showQuestion() {
            const q = quizQuestions[currentQuestionIndex];
            const qContainer = document.getElementById('quiz-question');
            const optionsContainer = document.getElementById('quiz-options');
            const feedback = document.getElementById('quiz-feedback');
            const nextBtn = document.getElementById('next-btn');
            
            document.getElementById('quiz-progress').textContent = `第 ${currentQuestionIndex + 1}/${TOTAL_QUESTIONS} 題`;
            feedback.classList.add('hidden');
            nextBtn.classList.add('hidden');
            
            // Create visible blank spot
            const formattedSentence = q.sentence.replace('________', '<span class="px-6 py-1 mx-2 border-b-2 border-dashed border-indigo-600 text-indigo-700 font-bold bg-white rounded shadow-sm">？</span>');
            qContainer.innerHTML = formattedSentence;

            // Gather options (1 correct, 3 wrong from total dataset)
            const distractors = vocabData
                .filter(v => v.word !== q.word)
                .sort(() => 0.5 - Math.random())
                .slice(0, 3);
            
            const options = [...distractors, q].sort(() => 0.5 - Math.random());
            
            optionsContainer.innerHTML = '';
            options.forEach(opt => {
                const btn = document.createElement('button');
                btn.className = 'py-4 px-6 bg-white border-2 border-gray-100 rounded-2xl hover:border-indigo-400 hover:bg-indigo-50/50 transition-all font-bold text-gray-700 text-left shadow-sm flex items-center justify-between active:scale-95';
                btn.innerHTML = `<span>${opt.word}</span> <span class="text-xs text-gray-400 font-normal font-mono">${opt.jyutping}</span>`;
                btn.onclick = () => checkAnswer(opt.word, q.word, btn);
                optionsContainer.appendChild(btn);
            });
        }

        function checkAnswer(selected, correct, btn) {
            const options = document.querySelectorAll('#quiz-options button');
            options.forEach(b => b.disabled = true); // Disable further clicking

            const feedback = document.getElementById('quiz-feedback');
            const qContainer = document.getElementById('quiz-question');

            if (selected === correct) {
                score += 10;
                document.getElementById('quiz-score').textContent = `累積得分: ${score}`;
                btn.classList.add('bg-green-100', 'border-green-500', 'text-green-800');
                feedback.innerHTML = `🌟 <strong>答對了！</strong> 「${correct}」就是最佳答案。`;
                feedback.className = 'text-center font-bold text-lg p-4 rounded-2xl mb-6 bg-green-50 text-green-700';
                qContainer.innerHTML = quizQuestions[currentQuestionIndex].sentence.replace('________', `<span class="px-4 text-green-700 font-extrabold border-b-2 border-green-500">${correct}</span>`);
            } else {
                btn.classList.add('bg-red-100', 'border-red-500', 'text-red-800');
                feedback.innerHTML = `❌ <strong>再接再厲！</strong> 正確答案應該是「<span class="text-green-700">${correct}</span>」。`;
                feedback.className = 'text-center font-bold text-lg p-4 rounded-2xl mb-6 bg-red-50 text-red-700';
                
                options.forEach(b => {
                    if (b.textContent.includes(correct)) {
                        b.classList.add('border-green-500', 'bg-green-50', 'text-green-800');
                    }
                });
            }

            feedback.classList.remove('hidden');
            document.getElementById('next-btn').classList.remove('hidden');
        }

        function nextQuestion() {
            currentQuestionIndex++;
            if (currentQuestionIndex < TOTAL_QUESTIONS) {
                showQuestion();
            } else {
                showResult();
            }
        }

        function showResult() {
            document.getElementById('quiz-content').classList.add('hidden');
            const resultArea = document.getElementById('quiz-result');
            resultArea.classList.remove('hidden');
            
            const scoreDisplay = document.getElementById('final-score');
            scoreDisplay.textContent = `你的總分是: ${score} / 100`;

            const commentDisplay = document.getElementById('final-comment');
            const trophy = document.getElementById('quiz-trophy');
            
            if (score === 100) {
                trophy.textContent = "🏆";
                commentDisplay.textContent = "太驚人了！10題全部答對，你是真正的語文小狀元！";
            } else if (score >= 80) {
                trophy.textContent = "🌟";
                commentDisplay.textContent = "非常好！只差一點點就完美了，繼續保持下去！";
            } else if (score >= 60) {
                trophy.textContent = "👍";
                commentDisplay.textContent = "做得好！你已經掌握了大部分的核心詞彙，再加把勁！";
            } else {
                trophy.textContent = "📖";
                commentDisplay.textContent = "沒關係，多讀幾次學習卡，下次你一定能拿到更高的分數！";
            }
        }

        // --- Text To Speech ---
        function speak(text) {
            if ('speechSynthesis' in window) {
                window.speechSynthesis.cancel(); // Stop any currently speaking speech
                const utterance = new SpeechSynthesisUtterance(text);
                utterance.lang = 'zh-HK';
                utterance.rate = 0.85; // Slightly slower for primary kids
                window.speechSynthesis.speak(utterance);
            } else {
                const toast = document.getElementById('toast');
                toast.textContent = "抱歉，您的設備不支援系統語音播放。";
                toast.classList.remove('hidden');
                setTimeout(() => toast.classList.add('hidden'), 3000);
            }
        }

        // --- On Load initialization ---
        window.onload = () => {
            renderContent();
        };
    </script>
</body>
</html>
