<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>小學語文互動學習寶庫</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Noto Sans TC', sans-serif;
            background-color: #f8fafc;
        }
        .card-flip-inner {
            transition: transform 0.6s;
            transform-style: preserve-3d;
        }
        .card-flipped .card-flip-inner {
            transform: rotateY(180deg);
        }
        .card-front, .card-back {
            backface-visibility: hidden;
            -webkit-backface-visibility: hidden;
        }
        .card-back {
            transform: rotateY(180deg);
        }
        .perspective {
            perspective: 1000px;
        }
        .nav-active {
            border-bottom: 3px solid white;
            font-weight: bold;
        }
    </style>
</head>
<body class="pb-20">

    <!-- Header & Nav -->
    <header class="bg-gradient-to-r from-indigo-600 to-blue-500 text-white shadow-lg mb-8">
        <div class="max-w-6xl mx-auto py-8 px-4 text-center">
            <h1 class="text-3xl md:text-4xl font-bold mb-3">📚 互動詞彙學習寶庫</h1>
            <nav class="flex justify-center gap-8 mt-6">
                <button onclick="switchPage('study')" id="nav-study" class="nav-active pb-1 hover:text-blue-100 transition">詞彙學習卡</button>
                <button onclick="switchPage('quiz')" id="nav-quiz" class="pb-1 hover:text-blue-100 transition">選詞填充挑戰</button>
            </nav>
        </div>
    </header>

    <main class="max-w-6xl mx-auto px-4">
        
        <!-- Study Page -->
        <div id="page-study">
            <!-- Filter Tabs -->
            <div class="flex flex-wrap justify-center gap-3 mb-10" id="unit-filters">
                <button onclick="filterUnit('all')" class="unit-btn active bg-indigo-600 text-white px-6 py-2 rounded-full shadow-md hover:bg-indigo-700 transition">全部顯示</button>
                <button onclick="filterUnit('u9')" class="unit-btn bg-white text-indigo-600 px-6 py-2 rounded-full shadow hover:bg-indigo-50 transition border border-indigo-100">單元九</button>
                <button onclick="filterUnit('u11')" class="unit-btn bg-white text-indigo-600 px-6 py-2 rounded-full shadow hover:bg-indigo-50 transition border border-indigo-100">單元十一</button>
                <button onclick="filterUnit('u12')" class="unit-btn bg-white text-indigo-600 px-6 py-2 rounded-full shadow hover:bg-indigo-50 transition border border-indigo-100">單元十二</button>
                <button onclick="filterUnit('u13')" class="unit-btn bg-white text-indigo-600 px-6 py-2 rounded-full shadow hover:bg-indigo-50 transition border border-indigo-100">單元十三</button>
            </div>
            <div id="content-area"></div>
        </div>

        <!-- Quiz Page -->
        <div id="page-quiz" class="hidden">
            <div class="max-w-3xl mx-auto bg-white rounded-3xl shadow-xl p-8 border-t-8 border-indigo-500">
                <div id="quiz-intro" class="text-center">
                    <h2 class="text-2xl font-bold text-gray-800 mb-4">準備好接受挑戰了嗎？</h2>
                    <p class="text-gray-600 mb-8">系統將隨機挑選 10 道填充題，請選擇正確的詞語填入空格中。</p>
                    <button onclick="startQuiz()" class="bg-indigo-600 text-white px-10 py-3 rounded-full text-xl font-bold shadow-lg hover:bg-indigo-700 transition-all transform hover:scale-105">
                        開始 10 題挑戰 🚀
                    </button>
                </div>

                <div id="quiz-content" class="hidden">
                    <div class="flex justify-between items-center mb-6">
                        <span id="quiz-progress" class="text-sm font-bold text-indigo-500 bg-indigo-50 px-3 py-1 rounded-full">第 1/10 題</span>
                        <span id="quiz-score" class="text-sm font-bold text-orange-500">得分: 0</span>
                    </div>
                    
                    <div id="quiz-question" class="text-xl leading-relaxed text-gray-800 mb-10 bg-slate-50 p-6 rounded-2xl border-l-4 border-indigo-400">
                        <!-- Question text here -->
                    </div>

                    <div id="quiz-options" class="grid grid-cols-2 gap-4 mb-8">
                        <!-- Options here -->
                    </div>

                    <div id="quiz-feedback" class="text-center font-bold text-lg hidden p-4 rounded-xl mb-4"></div>
                    
                    <button id="next-btn" onclick="nextQuestion()" class="hidden w-full bg-blue-500 text-white py-3 rounded-xl font-bold hover:bg-blue-600 transition">
                        下一題
                    </button>
                </div>

                <div id="quiz-result" class="hidden text-center py-10">
                    <h2 class="text-4xl font-bold text-indigo-600 mb-4">挑戰完成！</h2>
                    <p id="final-score" class="text-2xl text-gray-700 mb-8"></p>
                    <button onclick="startQuiz()" class="bg-indigo-600 text-white px-8 py-3 rounded-full font-bold shadow-md hover:bg-indigo-700">
                        再玩一次
                    </button>
                </div>
            </div>
        </div>

    </main>

    <div id="toast" class="fixed bottom-5 right-5 bg-gray-800 text-white px-4 py-2 rounded shadow-lg hidden z-50"></div>

    <script>
        const vocabData = [
            // 單元九
            { unit: 'u9', lesson: '《紙船》', word: '倘若', jyutping: 'tong2 joek6', zh: '如果、假使', en: 'If', type: '應用', sentence: '________明天不下雨，我們就去野餐。' },
            { unit: 'u9', lesson: '《紙船》', word: '悲哀', jyutping: 'bei1 oi1', zh: '傷心難過', en: 'Sorrowful', type: '應用', sentence: '聽到這個不幸的消息，他感到萬分________。' },
            { unit: 'u9', lesson: '《紙船》', word: '吹捲', jyutping: 'ceoi1 gyun2', zh: '風吹動並使之捲曲', en: 'To blow and curl', type: '應用', sentence: '強風把地上的落葉________到半空中。' },
            { unit: 'u9', lesson: '《紙船》', word: '灰心', jyutping: 'fui1 sam1', zh: '失去信心、沮喪', en: 'Discouraged', type: '應用', sentence: '雖然試驗失敗了，但他一點也不________，決定再試一次。' },
            { unit: 'u9', lesson: '《我是蘋果》', word: '探索', jyutping: 'taam3 sok3', zh: '多方尋求答案', en: 'Explore', type: '應用', sentence: '科學家不斷________宇宙的奧秘。' },
            { unit: 'u9', lesson: '《我是蘋果》', word: '充飢', jyutping: 'cung1 gei1', zh: '解餓', en: 'Satisfy hunger', type: '應用', sentence: '登山者帶了一些餅乾，預備在山上________之用。' },
            { unit: 'u9', lesson: '《我是蘋果》', word: '解渴', jyutping: 'gaai2 hot3', zh: '消除渴感', en: 'Quench thirst', type: '應用', sentence: '在炎熱的夏天，西瓜是________的最好水果。' },
            { unit: 'u9', lesson: '《我是蘋果》', word: '痛苦', jyutping: 'tung3 fu2', zh: '身心感到難受', en: 'Pain', type: '應用', sentence: '生病發燒的時候，身體會感到非常________。' },

            // 單元十一
            { unit: 'u11', lesson: '《大老虎》', word: '感激', jyutping: 'gam2 gik1', zh: '深深感謝', en: 'Grateful', type: '應用', sentence: '我十分________老師對我的悉心教導。' },
            { unit: 'u11', lesson: '《大老虎》', word: '相信', jyutping: 'soeng1 seon3', zh: '認為正確', en: 'Believe', type: '應用', sentence: '只要努力，我________一定可以取得好成績。' },
            { unit: 'u11', lesson: '《大老虎》', word: '尊敬', jyutping: 'zyun1 ging3', zh: '重視並有禮貌', en: 'Respect', type: '應用', sentence: '學生應該________老師，這是基本的禮貌。' },
            { unit: 'u11', lesson: '《大老虎》', word: '貪吃', jyutping: 'taam1 heik3', zh: '喜歡吃東西', en: 'Gluttonous', type: '應用', sentence: '那隻老鼠因為________，結果中了獵人的圈套。' },
            { unit: 'u11', lesson: '《畫鳥的獵人》', word: '習性', jyutping: 'zaap6 sing3', zh: '習慣', en: 'Habits', type: '應用', sentence: '了解動物的________，有助於我們更好地保護牠們。' },
            { unit: 'u11', lesson: '《畫鳥的獵人》', word: '把握', jyutping: 'baa2 ak1', zh: '成功的機會', en: 'Grasp', type: '應用', sentence: '機會稍縱即逝，我們一定要好好________。' },
            { unit: 'u11', lesson: '《畫鳥的獵人》', word: '決定', jyutping: 'kyut3 ding6', zh: '做出選擇', en: 'Decide', type: '應用', sentence: '經過考慮，他________暑假去參加童軍營。' },
            { unit: 'u11', lesson: '《畫鳥的獵人》', word: '嚴肅', jyutping: 'jim4 suk1', zh: '莊重', en: 'Serious', type: '應用', sentence: '看見爸爸臉色________，我知道自己一定做錯事了。' },

            // 單元十二
            { unit: 'u12', lesson: '《第一次探訪》', word: '寒暄', jyutping: 'hon4 hyun1', zh: '問候', en: 'Greetings', type: '應用', sentence: '他們兩人在客廳裡互相________了一會兒才開始談正事。' },
            { unit: 'u12', lesson: '《第一次探訪》', word: '陌生', jyutping: 'mak6 sang1', zh: '不熟悉', en: 'Stranger', type: '應用', sentence: '來到這個________的城市，我覺得有點不習慣。' },
            { unit: 'u12', lesson: '《第一次探訪》', word: '自豪', jyutping: 'zi6 hou4', zh: '感到光榮', en: 'Proud', type: '應用', sentence: '小明在校運會拿了金牌，父母都為他感到________。' },
            { unit: 'u12', lesson: '《第一次探訪》', word: '友善', jyutping: 'jau5 sin6', zh: '親切友好', en: 'Friendly', type: '應用', sentence: '鄰居家的小狗非常________，見到人會搖尾巴。' },
            { unit: 'u12', lesson: '《隱形人》', word: '處之泰然', jyutping: 'cyu2 zi1 taai3 jin4', zh: '鎮定自若', en: 'Calmness', type: '應用', sentence: '即使面對突如其來的困難，他依然能________。' },
            { unit: 'u12', lesson: '《隱形人》', word: '隱藏', jyutping: 'jan2 cong4', zh: '藏起來', en: 'To hide', type: '應用', sentence: '小兔把身體________在草叢中，躲避狐狸。' },
            { unit: 'u12', lesson: '《隱形人》', word: '遺忘', jyutping: 'wai4 mong4', zh: '忘記', en: 'Forget', type: '應用', sentence: '歷史是不應該被________的，我們要從中吸取教訓。' },
            { unit: 'u12', lesson: '《隱形人》', word: '慌張', jyutping: 'fong1 zoeng1', zh: '恐懼不知所措', en: 'Panic', type: '應用', sentence: '遇到突發事件時要保持冷靜，千萬不要________。' },

            // 單元十三
            { unit: 'u13', lesson: '《龍船比賽》', word: '五色繽紛', jyutping: 'ng5 sik1 ban1 fan1', zh: '色彩絢麗', en: 'Multi-colored', type: '應用', sentence: '節慶期間，街上掛滿了________的彩燈。' },
            { unit: 'u13', lesson: '《龍船比賽》', word: '神氣活現', jyutping: 'san4 hei3 wut6 jin6', zh: '得意、傲慢貌', en: 'High-spirited', type: '應用', sentence: '他穿上新的制服，走起路來________。' },
            { unit: 'u13', lesson: '《龍船比賽》', word: '健兒', jyutping: 'gin6 ji4', zh: '體育運動員', en: 'Athlete', type: '應用', sentence: '運動場上的________們正在奮力向終點衝刺。' },
            { unit: 'u13', lesson: '《中秋觀燈》', word: '燈火通明', jyutping: 'dang1 fo2 tung1 ming4', zh: '燈光燦爛', en: 'Brightly lit', type: '應用', sentence: '維多利亞公園在夜晚總是________，非常熱鬧。' },
            { unit: 'u13', lesson: '《中秋觀燈》', word: '賞月', jyutping: 'soeng2 jyut6', zh: '欣賞月色', en: 'Moon watching', type: '應用', sentence: '中秋節晚上，我們一家人到海邊吃月餅和________。' },
            { unit: 'u13', lesson: '《中秋觀燈》', word: '熱鬧', jyutping: 'jit6 naau6', zh: '繁盛活躍', en: 'Lively', type: '應用', sentence: '年宵市場裡人山人海，氣氛十分________。' }
        ];

        const unitNames = {
            'u9': '單元九：親情與自然',
            'u11': '單元十一：寓言故事',
            'u12': '單元十二：人際關懷',
            'u13': '單元十三：傳統節慶'
        };

        // --- Page Logic ---
        function switchPage(page) {
            document.getElementById('page-study').classList.toggle('hidden', page !== 'study');
            document.getElementById('page-quiz').classList.toggle('hidden', page !== 'quiz');
            document.getElementById('nav-study').className = page === 'study' ? 'nav-active pb-1' : 'pb-1';
            document.getElementById('nav-quiz').className = page === 'quiz' ? 'nav-active pb-1' : 'pb-1';
        }

        // --- Quiz Logic ---
        let currentQuestionIndex = 0;
        let score = 0;
        let quizQuestions = [];
        const TOTAL_QUESTIONS = 10;

        function startQuiz() {
            score = 0;
            currentQuestionIndex = 0;
            // Shuffle all and pick 10
            quizQuestions = [...vocabData].sort(() => 0.5 - Math.random()).slice(0, TOTAL_QUESTIONS);
            
            document.getElementById('quiz-intro').classList.add('hidden');
            document.getElementById('quiz-result').classList.add('hidden');
            document.getElementById('quiz-content').classList.remove('hidden');
            document.getElementById('quiz-score').textContent = `得分: ${score}`;
            
            showQuestion();
        }

        function showQuestion() {
            const q = quizQuestions[currentQuestionIndex];
            const qContainer = document.getElementById('quiz-question');
            const optionsContainer = document.getElementById('quiz-options');
            const feedback = document.getElementById('quiz-feedback');
            const nextBtn = document.getElementById('next-btn');
            
            document.getElementById('quiz-progress').textContent = `第 ${currentQuestionIndex + 1}/${TOTAL_QUESTIONS} 題`;
            feedback.classList.add('hidden');
            nextBtn.classList.add('hidden');
            
            const formattedSentence = q.sentence.replace('________', '<span class="px-6 py-1 mx-2 border-b-2 border-indigo-500 text-indigo-600 font-bold bg-white rounded shadow-inner">？</span>');
            qContainer.innerHTML = formattedSentence;

            const distractors = vocabData
                .filter(v => v.word !== q.word)
                .sort(() => 0.5 - Math.random())
                .slice(0, 3);
            
            const options = [...distractors, q].sort(() => 0.5 - Math.random());
            
            optionsContainer.innerHTML = '';
            options.forEach(opt => {
                const btn = document.createElement('button');
                btn.className = 'py-4 bg-white border-2 border-gray-100 rounded-2xl hover:border-indigo-300 hover:bg-indigo-50 transition-all font-bold text-gray-700 shadow-sm active:scale-95';
                btn.textContent = opt.word;
                btn.onclick = () => checkAnswer(opt.word, q.word, btn);
                optionsContainer.appendChild(btn);
            });
        }

        function checkAnswer(selected, correct, btn) {
            const options = document.querySelectorAll('#quiz-options button');
            options.forEach(b => b.disabled = true);

            const feedback = document.getElementById('quiz-feedback');
            const qContainer = document.getElementById('quiz-question');

            if (selected === correct) {
                score += 10;
                document.getElementById('quiz-score').textContent = `得分: ${score}`;
                btn.classList.add('bg-green-100', 'border-green-500', 'text-green-700');
                feedback.textContent = '✅ 太棒了！答對了。';
                feedback.className = 'text-center font-bold text-lg p-4 rounded-xl mb-4 bg-green-50 text-green-700';
                qContainer.innerHTML = quizQuestions[currentQuestionIndex].sentence.replace('________', `<span class="px-2 text-green-600 font-bold border-b-2 border-green-500">${correct}</span>`);
            } else {
                btn.classList.add('bg-red-100', 'border-red-500', 'text-red-700');
                feedback.textContent = `❌ 哎呀，再加油！正確答案是「${correct}」。`;
                feedback.className = 'text-center font-bold text-lg p-4 rounded-xl mb-4 bg-red-50 text-red-700';
                
                options.forEach(b => {
                    if (b.textContent === correct) b.classList.add('border-green-500', 'bg-green-50');
                });
            }

            feedback.classList.remove('hidden');
            document.getElementById('next-btn').classList.remove('hidden');
        }

        function nextQuestion() {
            currentQuestionIndex++;
            if (currentQuestionIndex < TOTAL_QUESTIONS) {
                showQuestion();
            } else {
                showResult();
            }
        }

        function showResult() {
            document.getElementById('quiz-content').classList.add('hidden');
            const resultArea = document.getElementById('quiz-result');
            resultArea.classList.remove('hidden');
            document.getElementById('final-score').textContent = `你的總分是: ${score} / 100`;
            
            let msg = score === 100 ? "完美！你已經完全掌握了！🏆" : (score >= 80 ? "很出色！繼續保持！🌟" : "不錯的嘗試，再多練習一下吧！📖");
            const msgP = document.createElement('p');
            msgP.className = "text-lg text-indigo-500 font-medium mb-6";
            msgP.textContent = msg;
            
            const scoreDisplay = document.getElementById('final-score');
            if (scoreDisplay.nextSibling && scoreDisplay.nextSibling.tagName === 'P') scoreDisplay.nextSibling.remove();
            scoreDisplay.parentNode.insertBefore(msgP, scoreDisplay.nextSibling);
        }

        // --- Study Page Logic ---
        function createCard(item) {
            const isApp = item.type === '應用';
            const themeColor = isApp ? 'border-orange-400' : 'border-emerald-400';
            const badgeClass = isApp ? 'bg-orange-100 text-orange-700' : 'bg-emerald-100 text-emerald-700';
            
            return `
                <div class="vocab-card h-52 perspective cursor-pointer" onclick="this.classList.toggle('card-flipped')">
                    <div class="card-flip-inner relative w-full h-full text-center">
                        <div class="card-front absolute w-full h-full bg-white rounded-xl shadow-sm p-4 flex flex-col justify-center items-center border-b-4 ${themeColor}">
                            <span class="absolute top-3 left-3 text-[10px] font-bold px-2 py-0.5 rounded-full ${badgeClass}">${item.type}</span>
                            <h2 class="text-2xl font-bold text-gray-800 mb-1">${item.word}</h2>
                            <p class="text-blue-500 text-xs font-medium">${item.jyutping}</p>
                            <p class="text-gray-400 text-[9px] mt-2">${item.lesson}</p>
                            <button onclick="event.stopPropagation(); speak('${item.word}')" class="mt-3 p-1.5 bg-gray-50 rounded-full hover:bg-blue-50 transition border border-gray-100 text-xs">🔊</button>
                        </div>
                        <div class="card-back absolute w-full h-full bg-slate-50 text-slate-900 rounded-xl shadow-sm p-4 flex flex-col justify-center items-center border-b-4 border-slate-400">
                            <div class="text-left w-full overflow-hidden">
                                <p class="text-[9px] uppercase font-bold text-slate-400 mb-1">中文解釋</p>
                                <p class="text-xs font-medium leading-tight mb-2 truncate-2-lines">${item.zh}</p>
                                <div class="pt-1.5 border-t border-slate-200">
                                    <p class="text-[9px] uppercase font-bold text-slate-400 mb-1">English</p>
                                    <p class="text-xs italic font-medium text-slate-600">${item.en}</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            `;
        }

        function renderContent(filterUnitId = 'all') {
            const container = document.getElementById('content-area');
            container.innerHTML = '';
            const unitsToDisplay = filterUnitId === 'all' ? Object.keys(unitNames) : [filterUnitId];

            unitsToDisplay.forEach(uId => {
                const unitData = vocabData.filter(i => i.unit === uId);
                const appVocab = unitData.filter(i => i.type === '應用');
                const readVocab = unitData.filter(i => i.type === '認讀');

                const section = document.createElement('div');
                section.className = 'mb-12';
                section.innerHTML = `
                    <h2 class="text-xl font-bold text-gray-700 mb-4 flex items-center">
                        <span class="bg-indigo-600 w-1.5 h-6 rounded-full mr-3"></span>
                        ${unitNames[uId]}
                    </h2>
                    <div class="mb-6">
                        <h3 class="text-sm font-bold text-orange-600 mb-3 flex items-center">✍️ 應用部</h3>
                        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
                            ${appVocab.map(createCard).join('')}
                        </div>
                    </div>
                    ${readVocab.length > 0 ? `
                    <div>
                        <h3 class="text-sm font-bold text-emerald-600 mb-3 flex items-center">📖 認讀部</h3>
                        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
                            ${readVocab.map(createCard).join('')}
                        </div>
                    </div>` : ''}
                `;
                container.appendChild(section);
            });
        }

        function filterUnit(unitId) {
            document.querySelectorAll('.unit-btn').forEach(btn => {
                btn.classList.remove('bg-indigo-600', 'text-white');
                btn.classList.add('bg-white', 'text-indigo-600');
            });
            event.target.classList.remove('bg-white', 'text-indigo-600');
            event.target.classList.add('bg-indigo-600', 'text-white');
            renderContent(unitId);
        }

        function speak(text) {
            if ('speechSynthesis' in window) {
                const utterance = new SpeechSynthesisUtterance(text);
                utterance.lang = 'zh-HK';
                window.speechSynthesis.speak(utterance);
            }
        }

        window.onload = () => renderContent();
    </script>
</body>
